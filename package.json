{
  "name": "ssgkimchi-hangeul-viewer",
  "version": "0.1.0",
  "description": "싹싹김치 한글뷰어 — 한글(HWP/HWPX)·PDF·Word·Excel·PowerPoint 멀티포맷 문서 뷰어",
  "author": "싹싹김치",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "copy:pdfjs": "node scripts/copy-pdfjs-assets.mjs",
    "predev": "node scripts/copy-pdfjs-assets.mjs",
    "prebuild": "node scripts/copy-pdfjs-assets.mjs",
    "dev": "node scripts/electron-vite.mjs dev",
    "build": "electron-vite build",
    "preview": "node scripts/electron-vite.mjs preview",
    "start": "node scripts/electron-vite.mjs preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:only": "playwright test",
    "build:win": "electron-vite build && electron-builder --win",
    "release:win": "npm run build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@rhwp/core": "^0.7.14",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.4.8",
    "pdfjs-dist": "^6.0.227",
    "pptx-preview": "^1.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.60.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.13.0",
    "jszip": "^3.10.1",
    "png-to-ico": "^3.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
